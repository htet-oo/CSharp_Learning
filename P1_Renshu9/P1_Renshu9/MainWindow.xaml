<Window x:Class="P1_Renshu9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="142" Width="484">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label Content="名前" FontWeight="Bold" Grid.Column="0"/>
            <TextBox Grid.Column="1" Width="200" Height="20" Background="LightGray" BorderThickness="2" HorizontalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" VerticalAlignment="Bottom" Margin="0,0,0,15">
            <Button Content="あいさつ" Width="80" Height="30"/>
        </Grid>
    </Grid>
</Window>
