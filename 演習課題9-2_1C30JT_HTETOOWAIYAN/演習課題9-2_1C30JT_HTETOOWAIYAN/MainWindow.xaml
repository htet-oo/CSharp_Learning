<Window x:Class="演習課題9_2_1C30JT_HTETOOWAIYAN.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="コメント登録画面" Height="445" Width="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Content="コメントを入力してください" Grid.Row="0" Margin="0,0,0,10"/>

        <TextBox Grid.Row="1"
                 Height="300"
                 BorderBrush="Black"
                 BorderThickness="1"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
            <Button Content="登録" Width="100" Margin="0,0,10,0"/>
            <Button Content="キャンセル" Width="100"/>
        </StackPanel>
    </Grid>
</Window>
